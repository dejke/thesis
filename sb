#!/usr/bin/env bash
#
# sb — thin wrapper around `docker compose` for the sandbox harness.
#
# Pins a single project name (so switching targets reconciles in place
# instead of leaving orphaned containers) and resolves the target's
# compose file from its name. Everything after the target is passed
# straight through to `docker compose` unchanged.
#
#   ./sb <target> <compose args...>
#
# Examples:
#   ./sb httpserver up -d --build      # bring up the httpserver target
#   ./sb httpserver exec attacker sh   # shell into the attacker
#   ./sb httpserver config             # print the resolved model
#   ./sb httpserver down               # tear it down
#
set -euo pipefail

target=${1:?usage: sb <target> <compose args...>}; shift

exec docker compose \
  -p sandbox \
  -f "targets/$target/docker-compose.yml" \
  "$@"
